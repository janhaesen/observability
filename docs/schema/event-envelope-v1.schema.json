{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/janhaesen/observability/docs/schema/event-envelope-v1.schema.json",
  "title": "Observability Event Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "name",
    "level",
    "timestamp",
    "message",
    "context",
    "payloadPresent",
    "payloadBase64"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "correlationId": {
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "type": "string",
      "enum": [
        "TRACE",
        "DEBUG",
        "INFO",
        "WARN",
        "ERROR"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "message",
        "stacktrace"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "stacktrace": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    },
    "payloadPresent": {
      "type": "boolean"
    },
    "payloadBase64": {
      "type": "string",
      "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
    }
  }
}

